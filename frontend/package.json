{
	"name": "score-my-recipe-frontend",
	"description": "The frontend for score-my-recipe",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"license": "AGPL-3.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/openfoodfacts/score-my-recipe.git"
	},
	"engines": {
		"node": ">=20 <25"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"format:changed": "pretty-quick --staged",
		"pre-commit": "pnpm format",
		"test": "vitest run --passWithNoTests",
		"i18nsync": "tsx scripts/i18n-sync.ts --sync --ref en-US.json",
		"i18ncheck": "tsx scripts/i18n-sync.ts --check --ref en-US.json"
	},
